---
import WorkCard from './WorkCard.astro';
import worksData from '../../data/works.json';

interface Props {
  currentTags: string[];
  currentSlug: string;
  maxItems?: number;
}

const { currentTags, currentSlug, maxItems = 4 } = Astro.props;

// 同タグの作品を絞り込み（currentSlugを除外）
const allWorks = worksData.works;
const related = allWorks
  .filter(w => {
    if (w.review_slug === currentSlug) return false;
    const workTags = [...(w.genres || [])];
    return workTags.some(t => currentTags.includes(t));
  })
  .slice(0, maxItems);
---

{related.length > 0 && (
  <section class="related-works">
    <h2 class="related-works__title">関連作品</h2>
    <div class="related-works__grid">
      {related.map(work => (
        <WorkCard
          id={work.id}
          title={work.title}
          author={work.author}
          author_slug={work.author_slug}
          price={work.price}
          release_date={work.release_date}
          genres={work.genres}
          thumbnail={work.thumbnail}
          fanza_link={work.fanza_link}
          review_slug={work.review_slug}
          pages={work.pages}
          rating={work.rating}
        />
      ))}
    </div>
  </section>
)}

<style>
.related-works {
  margin-top: 3rem;
  padding-top: 2rem;
  border-top: 1px solid var(--color-border, #2a2a40);
}
.related-works__title {
  font-size: 1.2rem;
  font-weight: 900;
  color: var(--color-text, #e8e8f0);
  margin: 0 0 1.2rem;
  padding-left: 0.8rem;
  border-left: 4px solid var(--color-accent, #c084fc);
}
.related-works__grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
}
@media (min-width: 640px) {
  .related-works__grid {
    grid-template-columns: repeat(4, 1fr);
  }
}
</style>
