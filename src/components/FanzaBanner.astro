---
const ALL_BANNERS = [
  { id: '1900_300_250', expires: '2026-04-30T23:59:59+09:00' },
  { id: '1899_300_250', expires: '2026-04-30T23:59:59+09:00' },
  { id: '1921_300_250', expires: '2026-04-30T23:59:59+09:00' },
  { id: '1894_300_250', expires: '2026-05-13T23:59:59+09:00' },
  { id: '1895_300_250', expires: '2026-05-13T23:59:59+09:00' },
  { id: '1896_300_250', expires: '2026-05-13T23:59:59+09:00' },
];
const now = new Date();
const activeBanners = ALL_BANNERS.filter(b => new Date(b.expires) >= now);
---
{activeBanners.length > 0 ? (
  <div class="banner-carousel">
    <div class="banner-track" id="banner-track">
      {activeBanners.map((b) => (
        <div class="banner-slide">
          <ins class="widget-banner"></ins>
          <script
            class="widget-banner-script"
            src={`https://widget-view.dmm.co.jp/js/banner_placement.js?affiliate_id=yukine0423-002&banner_id=${b.id}`}
          ></script>
        </div>
      ))}
    </div>
  </div>
) : null}

<style>
  .banner-carousel {
    overflow: hidden;
    max-width: 940px;
    margin: 1.5rem auto 2rem;
  }
  .banner-track {
    display: flex;
    gap: 20px;
    transition: transform 0.6s ease-in-out;
  }
  .banner-slide {
    flex: 0 0 300px;
    min-height: 250px;
  }
  @media (max-width: 768px) {
    .banner-carousel { max-width: 320px; }
  }
</style>

<script is:inline>
  (function() {
    const track = document.getElementById('banner-track');
    if (!track) return;
    const slides = track.querySelectorAll('.banner-slide');
    const total = slides.length;
    if (total <= 1) return;
    let position = 0;
    const slideWidth = 320;
    setInterval(() => {
      position = (position + 1) % total;
      track.style.transform = `translateX(-${position * slideWidth}px)`;
    }, 10000);
  })();
</script>
