---
interface Props {
  id: string;
  title: string;
  author: string;
  author_slug: string;
  price: number;
  release_date: string;
  genres: string[];
  thumbnail: string;
  fanza_link: string;
  review_slug: string | null;
  pages?: number;
  rating?: number;
}

const { id, title, author, author_slug, price, release_date, genres, thumbnail, fanza_link, review_slug, pages, rating } = Astro.props;

const releaseDateFormatted = new Date(release_date).toLocaleDateString('ja-JP', {
  year: 'numeric', month: 'long', day: 'numeric'
});

const ratingStars = rating ? Math.round(rating) : 0;
---

<article class="work-card" data-id={id} data-title={title} data-author={author} data-price={price} data-date={release_date} data-genres={genres.join(',')}>
  <div class="work-card__thumb">
    <img src={thumbnail} alt={title} loading="lazy" width="300" height="420" />
    {rating && (
      <div class="work-card__rating">
        {'★'.repeat(ratingStars)}{'☆'.repeat(5 - ratingStars)}
        <span class="work-card__rating-num">{rating.toFixed(1)}</span>
      </div>
    )}
    <button class="work-card__fav-btn" data-work-id={id} aria-label="お気に入り">
      <svg class="fav-icon fav-icon--off" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      <svg class="fav-icon fav-icon--on" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" stroke="none"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
    </button>
  </div>
  <div class="work-card__body">
    <div class="work-card__title">{title}</div>
    <a href={`/authors/${author_slug}/`} class="work-card__author">✍ {author}</a>
    <div class="work-card__meta">
      <span class="work-card__price">¥{price.toLocaleString()}</span>
      {pages && <span class="work-card__pages">{pages}P</span>}
      <span class="work-card__date">{releaseDateFormatted}</span>
    </div>
    <div class="work-card__genres">
      {genres.map(g => <span class="work-card__genre">{g}</span>)}
    </div>
    <div class="work-card__actions">
      <a href={fanza_link} target="_blank" rel="noopener noreferrer nofollow" class="btn-fanza">
        FANZAで見る
      </a>
      {review_slug && (
        <a href={`/posts/${review_slug}/`} class="btn-review">
          レビューを読む
        </a>
      )}
    </div>
  </div>
</article>

<style>
.work-card {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: 12px;
  overflow: hidden;
  transition: transform 0.2s, box-shadow 0.2s;
  display: flex;
  flex-direction: column;
}
.work-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 24px rgba(224, 64, 251, 0.2);
}
.work-card__thumb {
  position: relative;
  aspect-ratio: 5/7;
  overflow: hidden;
  background: #0d0d1a;
}
.work-card__thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.work-card__rating {
  position: absolute;
  bottom: 0.4rem;
  left: 0.4rem;
  background: rgba(13,13,26,0.85);
  padding: 0.2rem 0.5rem;
  border-radius: 6px;
  font-size: 0.75rem;
  color: #ffd700;
}
.work-card__rating-num {
  color: var(--color-text);
  margin-left: 0.3rem;
  font-size: 0.8rem;
}
.work-card__body {
  padding: 0.9rem;
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
  flex: 1;
}
.work-card__title {
  font-size: 0.9rem;
  font-weight: 700;
  color: var(--color-text);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.work-card__author {
  font-size: 0.8rem;
  color: var(--color-accent);
  text-decoration: none;
}
.work-card__author:hover { text-decoration: underline; }
.work-card__meta {
  display: flex;
  gap: 0.6rem;
  align-items: center;
  flex-wrap: wrap;
}
.work-card__price {
  font-size: 0.95rem;
  font-weight: 900;
  color: #ff4d8d;
}
.work-card__pages {
  font-size: 0.75rem;
  color: var(--color-text-muted);
  background: var(--color-surface-raised);
  padding: 0.1rem 0.4rem;
  border-radius: 4px;
}
.work-card__date {
  font-size: 0.75rem;
  color: var(--color-text-muted);
}
.work-card__genres {
  display: flex;
  flex-wrap: wrap;
  gap: 0.3rem;
}
.work-card__genre {
  font-size: 0.72rem;
  background: rgba(224, 64, 251, 0.15);
  color: var(--color-accent);
  border: 1px solid rgba(224, 64, 251, 0.3);
  padding: 0.1rem 0.4rem;
  border-radius: 4px;
}
.work-card__actions {
  display: flex;
  gap: 0.5rem;
  margin-top: auto;
  padding-top: 0.4rem;
}
.btn-fanza, .btn-review {
  flex: 1;
  text-align: center;
  padding: 0.45rem 0.5rem;
  border-radius: 6px;
  font-size: 0.8rem;
  font-weight: 700;
  text-decoration: none;
  transition: opacity 0.2s;
}
.btn-fanza {
  background: linear-gradient(135deg, #e040fb, #ff4d8d);
  color: #fff;
}
.btn-fanza:hover { opacity: 0.85; text-decoration: none; }
.btn-review {
  background: var(--color-surface-raised);
  color: var(--color-accent);
  border: 1px solid var(--color-border);
}
.btn-review:hover { border-color: var(--color-accent); text-decoration: none; }

/* お気に入りボタン */
.work-card__fav-btn {
  position: absolute;
  top: 0.4rem;
  right: 0.4rem;
  width: 32px;
  height: 32px;
  border: none;
  background: rgba(13,13,26,0.75);
  border-radius: 50%;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  transition: transform 0.15s, background 0.15s;
  z-index: 2;
}
.work-card__fav-btn:hover { background: rgba(13,13,26,0.92); transform: scale(1.1); }
.fav-icon--off { color: #aaa; display: block; }
.fav-icon--on  { color: #ff4d8d; display: none; }
.work-card__fav-btn.is-fav .fav-icon--off { display: none; }
.work-card__fav-btn.is-fav .fav-icon--on  { display: block; }
.work-card__fav-btn.fav-anim { animation: fav-pop 0.3s ease; }
@keyframes fav-pop {
  0%   { transform: scale(1); }
  50%  { transform: scale(1.4); }
  100% { transform: scale(1); }
}
</style>

<script is:inline>
(function() {
  var LS_KEY = 'yukine_favorites';

  function getFavs() {
    try { return new Set(JSON.parse(localStorage.getItem(LS_KEY) || '[]')); }
    catch(e) { return new Set(); }
  }
  function saveFavs(set) {
    localStorage.setItem(LS_KEY, JSON.stringify([...set]));
  }

  function updateBtn(btn, favs) {
    var id = btn.dataset.workId;
    if (favs.has(id)) { btn.classList.add('is-fav'); }
    else              { btn.classList.remove('is-fav'); }
  }

  function initFavButtons() {
    var favs = getFavs();
    document.querySelectorAll('.work-card__fav-btn').forEach(function(btn) {
      updateBtn(btn, favs);
      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        var id = btn.dataset.workId;
        var f = getFavs();
        if (f.has(id)) { f.delete(id); } else { f.add(id); }
        saveFavs(f);
        updateBtn(btn, f);
        btn.classList.remove('fav-anim');
        void btn.offsetWidth; // reflow
        btn.classList.add('fav-anim');
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFavButtons);
  } else {
    initFavButtons();
  }
})();
</script>
