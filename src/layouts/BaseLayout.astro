---
import '../styles/global.css';
import { getCollection } from 'astro:content';
interface Props {
  title: string;
  description: string;
  heroImage?: string;
  ogImage?: string;
  type?: string;
  tags?: string[];
  yukineVariant?: 'home' | 'post' | 'works' | 'author';
}

const { title, description, heroImage, ogImage, type = 'website', tags, yukineVariant = 'home' } = Astro.props;
const siteUrl = 'https://r18-blog.pages.dev';
const defaultOg = `${siteUrl}/images/og/og-default.png`;
const ogImageUrl = ogImage
  ? `${siteUrl}${ogImage}`
  : heroImage
    ? `${siteUrl}${heroImage}`
    : defaultOg;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? siteUrl);
const currentYear = new Date().getFullYear();
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | 月灯の書架</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <meta name="robots" content="index, follow" />
  <!-- OGP -->
  <meta property="og:type" content={type} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content="月灯の書架" />
  <meta property="og:locale" content="ja_JP" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />
  {tags && tags.map(tag => <meta property="article:tag" content={tag} />)}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700;900&display=swap" rel="stylesheet" />
  <!-- GA4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-17M7QN4XSW"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-17M7QN4XSW');
  </script>
  <script is:inline>
    // ダークテーマはデフォルト（R18サイトは常にダークテーマ）
    document.documentElement.style.colorScheme = 'dark';
  </script>
</head>
<body>
  <header class="site-header">
    <div class="site-header__inner">
      <a href="/" class="site-header__logo">🌙 月灯の書架</a>
      <nav class="site-header__nav">
        <a href="/">ホーム</a>
        <a href="/works/">作品一覧</a>
        <a href="/cv/">🎤 声優別</a>
        <a href="/circles/">🏷️ サークル別</a>
        <a href="/favorites/" class="nav-fav">♥ お気に入り</a>
        <a href="/yukine/">🌙 ゆきね</a>
      </nav>
      <!-- ハンバーガーボタン（モバイルのみ表示） -->
      <button class="hamburger-btn" id="hamburger-btn" aria-label="メニューを開く" aria-expanded="false">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
  </header>

  <!-- スライドメニュー -->
  <div class="slide-menu" id="slide-menu">
    <div class="slide-menu__overlay" id="slide-menu-overlay"></div>
    <nav class="slide-menu__nav">
      <button class="slide-menu__close" id="slide-menu-close" aria-label="メニューを閉じる">✕</button>
      <a href="/" class="slide-menu__item">🏠 ホーム</a>
      <a href="/works/" class="slide-menu__item">📚 作品一覧</a>
      <a href="/cv/" class="slide-menu__item">🎤 声優別レビュー</a>
      <a href="/circles/" class="slide-menu__item">🏷️ サークル別レビュー</a>
      <a href="/favorites/" class="slide-menu__item">♥ お気に入り</a>
      <a href="/yukine/" class="slide-menu__item">🌙 ゆきねについて</a>
    </nav>
  </div>

  <style>
    /* ハンバーガーボタン */
    .hamburger-btn {
      display: none;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.5rem;
      z-index: 200;
    }
    .hamburger-line {
      display: block;
      width: 24px;
      height: 2px;
      background: #e8d5ff;
      border-radius: 2px;
      transition: transform 0.2s, opacity 0.2s;
    }
    .hamburger-btn[aria-expanded="true"] .hamburger-line:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }
    .hamburger-btn[aria-expanded="true"] .hamburger-line:nth-child(2) {
      opacity: 0;
    }
    .hamburger-btn[aria-expanded="true"] .hamburger-line:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }

    /* スライドメニュー */
    .slide-menu {
      display: none;
    }
    .slide-menu__overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.5);
      z-index: 300;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s;
    }
    .slide-menu__nav {
      position: fixed;
      top: 0;
      right: -280px;
      width: 260px;
      height: 100dvh;
      background: #1a1a2e;
      border-left: 1px solid rgba(192, 132, 252, 0.3);
      z-index: 400;
      display: flex;
      flex-direction: column;
      padding: 1rem 0;
      transition: right 0.3s ease;
      box-shadow: -4px 0 20px rgba(160, 100, 220, 0.2);
    }
    .slide-menu.is-open .slide-menu__overlay {
      opacity: 1;
      pointer-events: auto;
    }
    .slide-menu.is-open .slide-menu__nav {
      right: 0;
    }
    .slide-menu__close {
      align-self: flex-end;
      background: none;
      border: none;
      color: #e8d5ff;
      font-size: 1.2rem;
      cursor: pointer;
      padding: 0.5rem 1rem;
      margin-bottom: 0.5rem;
    }
    .slide-menu__item {
      display: block;
      color: #e8d5ff;
      text-decoration: none;
      font-size: 1rem;
      font-weight: 600;
      padding: 0.85rem 1.5rem;
      border-bottom: 1px solid rgba(192, 132, 252, 0.15);
      transition: background 0.2s, color 0.2s;
    }
    .slide-menu__item:hover {
      background: rgba(192, 132, 252, 0.15);
      color: #c084fc;
      text-decoration: none;
    }

    @media (max-width: 600px) {
      .hamburger-btn {
        display: flex;
      }
      .slide-menu {
        display: block;
      }
    }
  </style>

  <main>
    <slot />
  </main>

  <button id="scroll-top-btn" class="scroll-top-btn" aria-label="トップに戻る">↑</button>

  <footer class="site-footer">
    <div class="site-footer__inner">
      <div class="site-footer__links">
        <a href="/">ホーム</a>
        <a href="/works/">作品一覧</a>
        <a href="/favorites/">♥ お気に入り</a>
        <a href="/about/">このサイトについて</a>
        <a href="/contact/">お問い合わせ</a>
        <a href="/privacy/">プライバシーポリシー</a>
        <a href="/sitemap-index.xml">サイトマップ</a>
      </div>
      <p>© {currentYear} 月灯の書架</p>
      <p class="site-footer__affiliate">
        本サイトはFANZA（DMMアダルト）アフィリエイトプログラムを利用しています。<br />
        掲載価格は記事作成時点のものです。実際の価格はリンク先でご確認ください。<br />
        本サイトは18歳以上の方を対象としています。
      </p>
    </div>
  </footer>

  <!-- 年齢確認モーダル（Cookie未設定の場合に表示） -->
  <div id="age-verify-overlay" class="age-overlay" style="display:none;">
    <div class="age-modal">
      <h2>⚠️ 年齢確認</h2>
      <p>
        本サイトは<strong>18歳以上の成人向けコンテンツ</strong>を含みます。<br />
        R18同人作品のレビュー・紹介サイトです。
      </p>
      <p class="warning">18歳未満の方はご利用いただけません。</p>
      <div class="age-buttons">
        <button class="age-btn-yes" id="age-yes">18歳以上です（入場する）</button>
        <button class="age-btn-no" id="age-no">18歳未満です（退出する）</button>
      </div>
    </div>
  </div>

  <script is:inline>
    // 年齢確認
    (function() {
      var COOKIE_KEY = 'r18_age_verified';
      function getCookie(name) {
        var m = document.cookie.match('(^|;)\\s*' + name + '\\s*=\\s*([^;]+)');
        return m ? m[2] : null;
      }
      function setCookie(name, value, days) {
        var d = new Date();
        d.setTime(d.getTime() + days * 24 * 60 * 60 * 1000);
        document.cookie = name + '=' + value + ';expires=' + d.toUTCString() + ';path=/';
      }
      var overlay = document.getElementById('age-verify-overlay');
      var yesBtn = document.getElementById('age-yes');
      var noBtn = document.getElementById('age-no');

      if (!getCookie(COOKIE_KEY)) {
        if (overlay) overlay.style.display = 'flex';
        document.body.style.overflow = 'hidden';
      }
      if (yesBtn) {
        yesBtn.addEventListener('click', function() {
          setCookie(COOKIE_KEY, '1', 365);
          if (overlay) overlay.style.display = 'none';
          document.body.style.overflow = '';
        });
      }
      if (noBtn) {
        noBtn.addEventListener('click', function() {
          window.location.href = 'https://www.google.co.jp/';
        });
      }
    })();

    // トップに戻るボタン
    (function() {
      var btn = document.getElementById('scroll-top-btn');
      if (!btn) return;
      window.addEventListener('scroll', function() {
        btn.classList.toggle('visible', window.scrollY > 400);
      });
      btn.addEventListener('click', function() {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    })();

    // ハンバーガーメニュー
    (function() {
      var hamburgerBtn = document.getElementById('hamburger-btn');
      var slideMenu = document.getElementById('slide-menu');
      var overlay = document.getElementById('slide-menu-overlay');
      var closeBtn = document.getElementById('slide-menu-close');
      if (!hamburgerBtn || !slideMenu) return;

      function openMenu() {
        slideMenu.classList.add('is-open');
        hamburgerBtn.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
      }
      function closeMenu() {
        slideMenu.classList.remove('is-open');
        hamburgerBtn.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }

      hamburgerBtn.addEventListener('click', function() {
        var isOpen = slideMenu.classList.contains('is-open');
        if (isOpen) closeMenu(); else openMenu();
      });
      if (overlay) overlay.addEventListener('click', closeMenu);
      if (closeBtn) closeBtn.addEventListener('click', closeMenu);
    })();
  </script>
</body>
</html>
