---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// 今日のゆきね：JSTで曜日を判定（毎朝cronで再ビルドされるため常に最新）
const days = ['sun', 'mon', 'tue', 'wed', 'thu', 'fri', 'sat'];
const dayNamesJa = ['日', '月', '火', '水', '木', '金', '土'];
const jstNow = new Date(Date.now() + 9 * 60 * 60 * 1000);
const dayIndex = jstNow.getUTCDay();
const dayKey = days[dayIndex];
const dayName = dayNamesJa[dayIndex];
---
<BaseLayout
  title="月灯の書架"
  description="白鳥ゆきね（しらとりゆきね）がお届けする、大人のための作品ガイド。厳選R18同人作品の詳細レビューをお届けします。18歳以上限定。"
>
  <section class="hero">
    <h1>🌙 月灯の書架</h1>
    <p>白鳥ゆきね（しらとりゆきね）がお届けする、大人のための作品ガイド。質にこだわった作品を厳選してご紹介します。</p>
    <p style="margin-top:0.8rem; font-size:0.85rem; color:#ff4d8d; font-weight:700;">⚠️ 本サイトは18歳以上の方を対象としています</p>
  </section>

  <!-- 今日のゆきね -->
  <section class="todays-yukine">
    <div class="todays-yukine__inner">
      <h2 class="todays-yukine__title">今日のゆきね（{dayName}曜日）</h2>
      <img
        src={`/images/yukine/daily/${dayKey}.png`}
        alt={`今日のゆきね（${dayName}曜日）`}
        class="todays-yukine__img"
        loading="eager"
        onclick="openYukineModal(this.src, this.alt)"
        style="cursor:zoom-in;"
      />
      <p class="todays-yukine__caption">タップで拡大</p>
    </div>
  </section>

  <div class="container" style="padding: 2rem 1rem;">
    <h2 style="font-size:1.4rem; font-weight:900; margin-bottom:1.5rem; color:#e040fb;">📚 最新レビュー</h2>

    {posts.length === 0 ? (
      <p style="color: var(--color-text-muted);">記事を準備中です。しばらくお待ちください。</p>
    ) : (
      <div class="article-grid">
        {posts.map(post => (
          <article class="article-card">
            <a href={`/posts/${post.id}/`}>
              {post.data.heroImage && (
                <img src={post.data.heroImage} alt={post.data.title} loading="lazy" />
              )}
              <div class="article-card__body">
                <div class="article-card__title">{post.data.title}</div>
                <div class="article-card__desc">{post.data.description}</div>
                <div class="article-card__date">
                  {new Date(post.data.pubDate).toLocaleDateString('ja-JP', {
                    year: 'numeric', month: 'long', day: 'numeric'
                  })}
                </div>
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="article-tags" style="margin-top:0.5rem;">
                    {post.data.tags.map(tag => (
                      <span class="article-tag">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          </article>
        ))}
      </div>
    )}
  </div>

</BaseLayout>

<style>
  .todays-yukine {
    background: linear-gradient(135deg, #1a0a2e 0%, #0d0520 100%);
    border-top: 1px solid #7b2fff33;
    border-bottom: 1px solid #7b2fff33;
    padding: 1.5rem 1rem;
    text-align: center;
  }
  .todays-yukine__inner {
    max-width: 420px;
    margin: 0 auto;
  }
  .todays-yukine__title {
    font-size: 1rem;
    font-weight: 700;
    color: #bb86fc;
    margin-bottom: 0.8rem;
    letter-spacing: 0.05em;
  }
  .todays-yukine__link {
    display: inline-block;
  }
  .todays-yukine__img {
    width: 100%;
    max-width: 320px;
    border-radius: 12px;
    border: 2px solid #7b2fff;
    box-shadow: 0 0 24px rgba(123, 47, 255, 0.35);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .todays-yukine__img:hover {
    transform: scale(1.02);
    box-shadow: 0 0 36px rgba(123, 47, 255, 0.55);
  }
  .todays-yukine__caption {
    margin-top: 0.6rem;
    font-size: 0.85rem;
  }
  .todays-yukine__caption a {
    color: #bb86fc;
    text-decoration: none;
  }
  .todays-yukine__caption a:hover {
    color: #e040fb;
  }
</style>
