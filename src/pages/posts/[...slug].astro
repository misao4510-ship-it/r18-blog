---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import RelatedWorks from '../../components/RelatedWorks.astro';
import FanzaLink from '../../components/FanzaLink.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, pubDate, updatedDate, heroImage, ogImage, tags, work_id } = post.data;
const siteUrl = 'https://r18-blog.pages.dev';
const canonicalUrl = `${siteUrl}/posts/${post.id}/`;
---
<BaseLayout {title} {description} {heroImage} {ogImage} type="article" {tags} yukineVariant="post">
  <article class="article-content">
    {heroImage && (
      <img src={heroImage} alt={title} style="width:100%; border-radius:12px; margin-bottom:1.5rem;" />
    )}
    <h1>{title}</h1>
    <div class="article-meta">
      <time datetime={pubDate.toISOString()}>
        公開: {pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      {updatedDate && (
        <span style="margin-left:1rem;">
          更新: {updatedDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
        </span>
      )}
    </div>
    {tags && tags.length > 0 && (
      <div class="article-tags" style="margin-bottom:1.5rem;">
        {tags.map(tag => <span class="article-tag">{tag}</span>)}
      </div>
    )}

    <div class="prose">
      <Content />
    </div>

    {work_id && (
      <div style="margin: 2rem 0; padding: 1.5rem; background: var(--color-surface-raised); border: 1px solid var(--color-border); border-radius: 12px; text-align: center;">
        <p style="color: var(--color-text-muted); font-size: 0.9rem; margin-bottom: 1rem;">この作品を購入する</p>
        <FanzaLink cid={work_id} />
      </div>
    )}

    <ShareButtons title={title} url={canonicalUrl} />

    <RelatedWorks currentTags={tags ?? []} currentSlug={post.id} maxItems={4} />

    <div style="margin-top:3rem; padding-top:1.5rem; border-top:1px solid var(--color-border);">
      <a href="/" style="color:var(--color-accent);">← 記事一覧に戻る</a>
    </div>
  </article>
</BaseLayout>

<style is:global>
  .prose p { margin-bottom: 1rem; }
  .prose h2 { font-size:1.4rem; margin:2rem 0 0.8rem; border-left:4px solid var(--color-accent); padding-left:0.8rem; }
  .prose h3 { font-size:1.2rem; margin:1.5rem 0 0.6rem; }
  .prose img { border-radius:8px; margin:1rem 0; }
  .prose ul, .prose ol { padding-left:1.5rem; margin-bottom:1rem; }
  .prose li { margin-bottom:0.4rem; }
  .prose blockquote {
    border-left:4px solid var(--color-accent);
    padding:0.5rem 1rem;
    background:var(--color-surface-raised);
    border-radius:0 8px 8px 0;
    margin:1rem 0;
    color:var(--color-text-muted);
  }
  .prose strong { color:var(--color-accent); }
  .prose a { color:var(--color-accent); }
  .prose table { width:100%; border-collapse:collapse; margin:1rem 0; }
  .prose th, .prose td { border:1px solid var(--color-border); padding:0.6rem 0.8rem; }
  .prose th { background:var(--color-surface-raised); font-weight:700; }
</style>
