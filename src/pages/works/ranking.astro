---
import BaseLayout from '../../layouts/BaseLayout.astro';
import rankingsData from '../../../data/rankings.json';

type RankItem = {
  rank: number;
  id: string;
  title: string;
  price: number;
  price_original: number | null;
  price_sale: number | null;
  discount_rate: number | null;
  is_on_sale: boolean;
  imageURL: string;
  affiliateURL: string;
  release_date: string;
};

const comicMonthly = rankingsData.comic_monthly as RankItem[];
const comicDaily   = rankingsData.comic_daily   as RankItem[];
const voiceMonthly = rankingsData.voice_monthly as RankItem[];
const voiceDaily   = rankingsData.voice_daily   as RankItem[];

const updatedDate = new Date(rankingsData.updated_at).toLocaleString('ja-JP', {
  year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit'
});

function medalEmoji(rank: number): string {
  if (rank === 1) return '🥇';
  if (rank === 2) return '🥈';
  if (rank === 3) return '🥉';
  return '';
}

function renderRankingList(items: RankItem[], listId: string, hidden: boolean) {
  const top3 = items.filter(i => i.rank <= 3);
  const rest  = items.filter(i => i.rank > 3);
  return { top3, rest, listId, hidden };
}

const lists = [
  renderRankingList(comicMonthly,  'list-comic_monthly',  false),
  renderRankingList(comicDaily,    'list-comic_daily',    true),
  renderRankingList(voiceMonthly,  'list-voice_monthly',  true),
  renderRankingList(voiceDaily,    'list-voice_daily',    true),
];
---

<BaseLayout
  title="ランキング"
  description="FANZA同人コミック・ボイス作品の月間・24時間ランキング。人気TOP30を一覧で確認できます。"
  yukineVariant="works"
>
  <div class="container ranking-page">
    <div class="ranking-header">
      <h1>🏆 ランキング</h1>
      <p class="ranking-updated">最終更新: {updatedDate}</p>
    </div>

    <!-- カテゴリタブ（上段） -->
    <div class="tab-group" id="category-tabs">
      <button class="tab active" data-category="comic">📖 コミック</button>
      <button class="tab" data-category="voice">🎤 ボイス</button>
    </div>

    <!-- 期間タブ（下段） -->
    <div class="tab-group" id="period-tabs">
      <button class="tab active" data-period="monthly">🔥 月間TOP30</button>
      <button class="tab" data-period="daily">🆕 24時間TOP30</button>
    </div>

    {lists.map(({ top3, rest, listId, hidden }) => (
      <div class="ranking-list" id={listId}
        data-category={listId.replace('list-', '').replace(/_monthly|_daily/, '')}
        data-period={listId.includes('monthly') ? 'monthly' : 'daily'}
        style={hidden ? 'display:none' : ''}>

        <!-- TOP3 グリッド -->
        {top3.length > 0 && (
          <div class="ranking-top3">
            {top3.map(item => (
              <a href={item.affiliateURL} target="_blank" rel="noopener noreferrer nofollow"
                class="ranking-card ranking-card--top3"
                data-rank={item.rank}>
                <div class="card-img-wrap">
                  <span class="medal-badge">{medalEmoji(item.rank)}</span>
                  <img src={item.imageURL} alt={item.title} loading="lazy" />
                  {item.is_on_sale && item.discount_rate && (
                    <span class="sale-badge">🔥{item.discount_rate}%OFF</span>
                  )}
                </div>
                <div class="card-body">
                  <p class="card-rank">第{item.rank}位</p>
                  <p class="card-title">{item.title}</p>
                  <div class="card-price-row">
                    {item.is_on_sale && item.price_original && item.price_sale ? (
                      <>
                        <span class="price-orig">¥{item.price_original.toLocaleString()}</span>
                        <span class="price-sale">¥{item.price_sale.toLocaleString()}</span>
                      </>
                    ) : (
                      <span class="price-normal">¥{item.price.toLocaleString()}</span>
                    )}
                  </div>
                  <span class="fanza-btn">✨ FANZAで購入</span>
                </div>
              </a>
            ))}
          </div>
        )}

        <!-- 4位以下 グリッド -->
        {rest.length > 0 && (
          <div class="ranking-grid">
            {rest.map(item => (
              <a href={item.affiliateURL} target="_blank" rel="noopener noreferrer nofollow"
                class="ranking-card"
                data-rank={item.rank}>
                <div class="card-img-wrap">
                  <span class="rank-num-badge">{item.rank}位</span>
                  <img src={item.imageURL} alt={item.title} loading="lazy" />
                  {item.is_on_sale && item.discount_rate && (
                    <span class="sale-badge">🔥{item.discount_rate}%OFF</span>
                  )}
                </div>
                <div class="card-body">
                  <p class="card-title card-title--sm">{item.title}</p>
                  <div class="card-price-row">
                    {item.is_on_sale && item.price_original && item.price_sale ? (
                      <>
                        <span class="price-orig">¥{item.price_original.toLocaleString()}</span>
                        <span class="price-sale">¥{item.price_sale.toLocaleString()}</span>
                      </>
                    ) : (
                      <span class="price-normal">¥{item.price.toLocaleString()}</span>
                    )}
                  </div>
                  <span class="fanza-btn fanza-btn--sm">FANZAで見る →</span>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    ))}
  </div>

  <style>
    .ranking-page {
      padding: 2rem 1rem;
      max-width: 1000px;
      margin: 0 auto;
    }
    .ranking-header {
      margin-bottom: 1.5rem;
    }
    .ranking-header h1 {
      font-size: 1.6rem;
      font-weight: 900;
      color: var(--color-text);
      margin-bottom: 0.3rem;
    }
    .ranking-updated {
      font-size: 0.8rem;
      color: var(--color-text-muted);
    }

    .tab-group {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 0.75rem;
      flex-wrap: wrap;
    }
    .tab {
      padding: 0.5rem 1.2rem;
      border: 1px solid var(--color-border);
      border-radius: 999px;
      background: var(--color-surface);
      color: var(--color-text-muted);
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.2s, color 0.2s, border-color 0.2s;
    }
    .tab.active {
      background: linear-gradient(135deg, #e040fb, #ff4d8d);
      color: #fff;
      border-color: transparent;
    }
    .tab:hover:not(.active) {
      border-color: var(--color-accent);
      color: var(--color-accent);
    }

    /* TOP3 グリッド */
    .ranking-top3 {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    /* 4位以下 グリッド */
    .ranking-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    /* カード共通 */
    .ranking-card {
      position: relative;
      border-radius: 12px;
      overflow: hidden;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      text-decoration: none;
      color: var(--color-text);
      transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
      display: flex;
      flex-direction: column;
    }
    .ranking-card:hover {
      transform: scale(1.03);
      border-color: var(--color-accent);
      box-shadow: 0 4px 16px rgba(224, 64, 251, 0.25);
      text-decoration: none;
      color: var(--color-text);
    }
    .ranking-card--top3[data-rank="1"] { border-color: #ffd700; border-width: 2px; }
    .ranking-card--top3[data-rank="2"] { border-color: #c0c0c0; border-width: 2px; }
    .ranking-card--top3[data-rank="3"] { border-color: #cd7f32; border-width: 2px; }

    /* 画像ラッパー */
    .card-img-wrap {
      position: relative;
      width: 100%;
      aspect-ratio: 2 / 3;
      overflow: hidden;
      border-radius: 8px 8px 0 0;
    }
    .card-img-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    /* メダルバッジ（TOP3） */
    .medal-badge {
      position: absolute;
      top: 6px;
      left: 6px;
      font-size: 2.2rem;
      z-index: 10;
      filter: drop-shadow(0 2px 6px rgba(0,0,0,0.85));
      line-height: 1;
    }

    /* 順位バッジ（4位以下） */
    .rank-num-badge {
      position: absolute;
      top: 6px;
      left: 6px;
      background: rgba(20, 0, 30, 0.78);
      color: #fff;
      font-size: 0.75rem;
      font-weight: 900;
      padding: 0.15rem 0.45rem;
      border-radius: 6px;
      z-index: 10;
    }

    /* セールバッジ */
    .sale-badge {
      position: absolute;
      top: 6px;
      right: 6px;
      background: linear-gradient(135deg, #ff4500, #ff8c00);
      color: #fff;
      font-size: 0.65rem;
      font-weight: 900;
      padding: 0.15rem 0.4rem;
      border-radius: 5px;
      z-index: 10;
    }

    /* カード本文 */
    .card-body {
      padding: 0.6rem 0.7rem 0.7rem;
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
      flex: 1;
    }
    .card-rank {
      font-size: 0.75rem;
      font-weight: 700;
      color: var(--color-accent);
      margin: 0;
    }
    .card-title {
      font-size: 0.88rem;
      font-weight: 700;
      line-height: 1.4;
      margin: 0;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .card-title--sm {
      font-size: 0.82rem;
      -webkit-line-clamp: 2;
    }
    .card-price-row {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      flex-wrap: wrap;
    }
    .price-normal { font-size: 0.9rem; font-weight: 900; color: #ff4d8d; }
    .price-orig   { font-size: 0.76rem; color: var(--color-text-muted); text-decoration: line-through; }
    .price-sale   { font-size: 0.9rem; font-weight: 900; color: #ff4500; }

    .fanza-btn {
      display: block;
      background: linear-gradient(135deg, #ff4d8d, #e040fb);
      color: #fff;
      text-align: center;
      padding: 0.55rem 0.5rem;
      border-radius: 8px;
      font-size: 0.82rem;
      font-weight: 700;
      margin-top: auto;
      transition: opacity 0.15s;
    }
    .fanza-btn:hover { opacity: 0.88; }
    .fanza-btn--sm {
      padding: 0.45rem 0.4rem;
      font-size: 0.76rem;
    }

    /* モバイル：1列 */
    @media (max-width: 640px) {
      .ranking-top3,
      .ranking-grid {
        grid-template-columns: 1fr;
      }
      .medal-badge { font-size: 1.8rem; }
    }
  </style>

  <script is:inline>
    (function() {
      var categoryBtns = document.querySelectorAll('#category-tabs .tab');
      var periodBtns = document.querySelectorAll('#period-tabs .tab');
      var lists = document.querySelectorAll('.ranking-list');
      var currentCategory = 'comic';
      var currentPeriod = 'monthly';

      function showList() {
        var targetId = 'list-' + currentCategory + '_' + currentPeriod;
        lists.forEach(function(list) {
          list.style.display = list.id === targetId ? 'block' : 'none';
        });
      }

      categoryBtns.forEach(function(btn) {
        btn.addEventListener('click', function() {
          categoryBtns.forEach(function(b) { b.classList.remove('active'); });
          btn.classList.add('active');
          currentCategory = btn.dataset.category;
          showList();
        });
      });

      periodBtns.forEach(function(btn) {
        btn.addEventListener('click', function() {
          periodBtns.forEach(function(b) { b.classList.remove('active'); });
          btn.classList.add('active');
          currentPeriod = btn.dataset.period;
          showList();
        });
      });
    })();
  </script>
</BaseLayout>
