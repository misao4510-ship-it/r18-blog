---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FanzaBanner from '../../components/FanzaBanner.astro';
import WorkCard from '../../components/WorkCard.astro';
import worksData from '../../../data/works.json';

const allWorks = worksData.works;
const saleWorks = allWorks.filter(w => w.is_on_sale);
const under100 = saleWorks.filter(w => (w.price_sale ?? w.price) <= 100).sort((a, b) => (a.price_sale ?? a.price) - (b.price_sale ?? b.price));
const under500 = saleWorks.filter(w => (w.price_sale ?? w.price) <= 500).sort((a, b) => (a.price_sale ?? a.price) - (b.price_sale ?? b.price));
const halfOff  = saleWorks.filter(w => (w.discount_rate ?? 0) >= 50).sort((a, b) => (b.discount_rate ?? 0) - (a.discount_rate ?? 0));
const allSale  = [...saleWorks].sort((a, b) => (a.price_sale ?? a.price) - (b.price_sale ?? b.price));
---

<BaseLayout
  title="セール作品一覧 | 月灯の書架"
  description={`現在${saleWorks.length}件がセール中！100円以下・ワンコイン・半額以下など価格帯別にFANZA同人作品を探せます。`}
  yukineVariant="works"
>
  <div class="container sale-page">
    <div class="sale-header">
      <h1>💰 セール作品</h1>
      <p class="sale-sub">お得な作品を価格帯別で探そう</p>
    </div>

    <FanzaBanner />

    <!-- 価格帯タブ -->
    <div class="tab-group" id="price-tabs" role="tablist">
      <button class="tab active" data-tab="under100" role="tab" aria-selected="true">
        🪙 100円以下
        <span class="tab-count">{under100.length}件</span>
      </button>
      <button class="tab" data-tab="under500" role="tab" aria-selected="false">
        💰 ワンコイン〜500円
        <span class="tab-count">{under500.length}件</span>
      </button>
      <button class="tab" data-tab="half" role="tab" aria-selected="false">
        🔥 半額以下
        <span class="tab-count">{halfOff.length}件</span>
      </button>
      <button class="tab" data-tab="all" role="tab" aria-selected="false">
        🎯 全セール
        <span class="tab-count">{allSale.length}件</span>
      </button>
    </div>

    <!-- 100円以下 -->
    <div class="sale-grid" id="tab-under100">
      {under100.map(w => (
        <WorkCard
          id={w.id}
          title={w.title}
          author={w.author}
          author_slug={w.author_slug}
          price={w.price}
          release_date={w.release_date}
          genres={w.genres}
          thumbnail={w.thumbnail}
          fanza_link={w.fanza_link}
          review_slug={w.review_slug}
          category={w.category}
          is_on_sale={w.is_on_sale}
          discount_rate={w.discount_rate}
          price_original={w.price_original}
          price_sale={w.price_sale}
        />
      ))}
      {under100.length === 0 && <p class="sale-empty">現在該当作品はありません</p>}
    </div>

    <!-- ワンコイン〜500円 -->
    <div class="sale-grid" id="tab-under500" style="display:none">
      {under500.map(w => (
        <WorkCard
          id={w.id}
          title={w.title}
          author={w.author}
          author_slug={w.author_slug}
          price={w.price}
          release_date={w.release_date}
          genres={w.genres}
          thumbnail={w.thumbnail}
          fanza_link={w.fanza_link}
          review_slug={w.review_slug}
          category={w.category}
          is_on_sale={w.is_on_sale}
          discount_rate={w.discount_rate}
          price_original={w.price_original}
          price_sale={w.price_sale}
        />
      ))}
      {under500.length === 0 && <p class="sale-empty">現在該当作品はありません</p>}
    </div>

    <!-- 半額以下 -->
    <div class="sale-grid" id="tab-half" style="display:none">
      {halfOff.map(w => (
        <WorkCard
          id={w.id}
          title={w.title}
          author={w.author}
          author_slug={w.author_slug}
          price={w.price}
          release_date={w.release_date}
          genres={w.genres}
          thumbnail={w.thumbnail}
          fanza_link={w.fanza_link}
          review_slug={w.review_slug}
          category={w.category}
          is_on_sale={w.is_on_sale}
          discount_rate={w.discount_rate}
          price_original={w.price_original}
          price_sale={w.price_sale}
        />
      ))}
      {halfOff.length === 0 && <p class="sale-empty">現在該当作品はありません</p>}
    </div>

    <!-- 全セール -->
    <div class="sale-grid" id="tab-all" style="display:none">
      {allSale.map(w => (
        <WorkCard
          id={w.id}
          title={w.title}
          author={w.author}
          author_slug={w.author_slug}
          price={w.price}
          release_date={w.release_date}
          genres={w.genres}
          thumbnail={w.thumbnail}
          fanza_link={w.fanza_link}
          review_slug={w.review_slug}
          category={w.category}
          is_on_sale={w.is_on_sale}
          discount_rate={w.discount_rate}
          price_original={w.price_original}
          price_sale={w.price_sale}
        />
      ))}
      {allSale.length === 0 && <p class="sale-empty">現在セール中の作品はありません</p>}
    </div>
  </div>

  <style>
    .sale-page {
      padding: 2rem 1rem;
      max-width: 1200px;
      margin: 0 auto;
    }
    .sale-header {
      margin-bottom: 1.5rem;
    }
    .sale-header h1 {
      font-size: 1.6rem;
      font-weight: 900;
      color: var(--color-text);
      margin-bottom: 0.3rem;
    }
    .sale-sub {
      font-size: 0.85rem;
      color: var(--color-text-muted);
    }

    .tab-group {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 1.5rem;
      flex-wrap: wrap;
    }
    .tab {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.5rem 1rem;
      border: 1px solid var(--color-border);
      border-radius: 999px;
      background: var(--color-surface);
      color: var(--color-text-muted);
      font-size: 0.85rem;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.2s, color 0.2s, border-color 0.2s;
      white-space: nowrap;
    }
    .tab.active {
      background: linear-gradient(135deg, #e040fb, #ff4d8d);
      color: #fff;
      border-color: transparent;
    }
    .tab:hover:not(.active) {
      border-color: var(--color-accent);
      color: var(--color-accent);
    }
    .tab-count {
      font-size: 0.78rem;
      opacity: 0.85;
    }

    .sale-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    .sale-empty {
      text-align: center;
      color: var(--color-text-muted);
      padding: 2rem;
      grid-column: 1 / -1;
    }

    @media (max-width: 768px) {
      .sale-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <script is:inline>
    (function() {
      var tabs = document.querySelectorAll('#price-tabs .tab');
      var grids = document.querySelectorAll('.sale-grid');

      tabs.forEach(function(tab) {
        tab.addEventListener('click', function() {
          var target = tab.dataset.tab;
          tabs.forEach(function(t) {
            t.classList.remove('active');
            t.setAttribute('aria-selected', 'false');
          });
          tab.classList.add('active');
          tab.setAttribute('aria-selected', 'true');
          grids.forEach(function(grid) {
            grid.style.display = grid.id === 'tab-' + target ? 'grid' : 'none';
          });
        });
      });
    })();
  </script>
</BaseLayout>
